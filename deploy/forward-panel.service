[Unit]
Description=Forward Panel Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/forward-panel
EnvironmentFile=/opt/forward-panel/panel.env
Environment=DATABASE=sqlite3:///opt/forward-panel/data/data.db
ExecStart=/opt/forward-panel/backend
Restart=always
RestartSec=5
LimitNOFILE=1048576
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/opt/forward-panel/data

[Install]
WantedBy=multi-user.target
